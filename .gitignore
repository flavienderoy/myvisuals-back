# ===========================
# Visuals.co — Global .gitignore
# ===========================

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
build/

# Environment variables
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vite
.vite/

# Docker
docker-compose.override.yml

# Test coverage
coverage/

# Temporary files
*.local
tmp/
temp/

# Nested front-end repo (separate git repo: myvisuals-client)
client/
